# Server Configuration
HOST=0.0.0.0
PORT=8000

# Model Settings
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Search Settings
TOP_K_CANDIDATES=1500
MAX_CAMPAIGNS_RETURNED=1000

# Data Paths
DATA_DIR=data
CAMPAIGNS_PATH=data/campaigns.jsonl
EMBEDDINGS_PATH=data/embeddings.npy
FAISS_INDEX_PATH=data/faiss.index
BLOCKLIST_PATH=data/blocklist.txt
TAXONOMY_PATH=data/taxonomy.json

# Graphiti Knowledge Graph (Optional)
GRAPHITI_ENABLED=false
GRAPHITI_NEO4J_URI=bolt://localhost:7687
GRAPHITI_NEO4J_USER=neo4j
GRAPHITI_NEO4J_PASSWORD=your_password
OPENROUTER_API_KEY=your_openrouter_key
GRAPHITI_LLM_MODEL=openai/gpt-4o
GRAPHITI_NAMESPACE=ad_retrieval
