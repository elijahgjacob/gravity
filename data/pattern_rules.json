{
  "rules": [
    {
      "rule_id": "marathon_planning",
      "name": "Marathon Event Planning",
      "description": "Detects users planning to attend a marathon event",
      "pattern": [
        {
          "step": 1,
          "keywords": ["marathon", "running", "shoes", "training", "race", "5k", "10k", "half marathon"],
          "category_match": ["running_shoes", "athletic_footwear", "sportswear"],
          "requires_location": false,
          "min_keyword_matches": 2
        },
        {
          "step": 2,
          "keywords": ["weather", "forecast", "temperature", "climate", "conditions"],
          "requires_location": true,
          "min_keyword_matches": 1
        },
        {
          "step": 3,
          "keywords": ["hotel", "accommodation", "lodging", "stay", "booking", "airbnb"],
          "requires_location": true,
          "location_must_match_step": 2,
          "min_keyword_matches": 1
        }
      ],
      "inferred_categories": ["airfare", "travel_packages", "event_tickets", "car_rental", "travel_insurance"],
      "confidence_threshold": 0.75,
      "time_window_hours": 168,
      "enabled": true,
      "priority": 1
    },
    {
      "rule_id": "vacation_planning",
      "name": "Vacation Planning",
      "description": "Detects users planning a vacation or leisure trip",
      "pattern": [
        {
          "step": 1,
          "keywords": ["vacation", "holiday", "trip", "travel", "getaway", "weekend"],
          "requires_location": false,
          "min_keyword_matches": 1
        },
        {
          "step": 2,
          "keywords": ["flight", "airfare", "tickets", "airline", "plane"],
          "requires_location": true,
          "min_keyword_matches": 1
        },
        {
          "step": 3,
          "keywords": ["hotel", "resort", "accommodation", "stay", "booking"],
          "requires_location": true,
          "location_must_match_step": 2,
          "min_keyword_matches": 1
        }
      ],
      "inferred_categories": ["car_rental", "travel_insurance", "tours", "activities", "restaurants", "luggage"],
      "confidence_threshold": 0.8,
      "time_window_hours": 336,
      "enabled": true,
      "priority": 2
    },
    {
      "rule_id": "shopping_research",
      "name": "Product Research & Shopping",
      "description": "Detects users researching products before purchase",
      "pattern": [
        {
          "step": 1,
          "keywords": ["best", "top", "review", "comparison", "vs", "versus"],
          "requires_location": false,
          "min_keyword_matches": 1
        },
        {
          "step": 2,
          "keywords": ["price", "cost", "cheap", "deal", "discount", "sale", "coupon"],
          "requires_location": false,
          "min_keyword_matches": 1
        }
      ],
      "inferred_categories": ["coupons", "price_comparison", "cashback", "financing", "warranty"],
      "confidence_threshold": 0.7,
      "time_window_hours": 24,
      "enabled": true,
      "priority": 3
    },
    {
